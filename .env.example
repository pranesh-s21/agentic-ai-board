# ── Cohere / North chat (POC) ────────────────────────────────────────────────
# Restart the chat server after changes: npm run dev:all

# ── LIVE North My Files (recommended) ────────────────────────────────────────
# Talks to your North agent on democloud — same as the North chat UI.
# My Files are read server-side by North; nothing is copied locally.
CHAT_PROVIDER=north
NORTH_BASE_URL=https://democloud.cohere.com
NORTH_AGENT_ID=your-agent-id-from-north-admin

# Auth: your dashboard COHERE_API_KEY does NOT access North My Files.
# Copy the Cookie header from browser DevTools while logged into North.
# Use single quotes — cookie values contain $ signs that break Docker Compose.
# NORTH_SESSION_COOKIE='...'

# Optional: restrict to specific My Files (comma-separated IDs). If unset, all processed files are used.
# NORTH_FILE_IDS=fb568743-5d75-4e3c-9495-0f26ab070c2e

# Optional OAuth (if your admin creates the app for you):
# NORTH_CLIENT_ID=app:...
# NORTH_CLIENT_SECRET=...

# ── Public Cohere API (mock board pack only — NOT North My Files) ────────────
# COHERE_API_KEY=
# COHERE_BASE_URL=https://api.cohere.com
# COHERE_MODEL=command-a-03-2025

PORT=3001

# ── Governance Actions (PostgreSQL) ───────────────────────────────────────────
# Local: docker compose up -d
DATABASE_URL=postgresql://board:board@localhost:5434/board_governance
# Supabase: paste connection string from Project Settings → Database
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_SSL=true

# MCP server for Cohere North (expose via ngrok)
MCP_PORT=3002
# Set to your ngrok hostname (no https://) — required for North to reach local MCP
# MCP_ALLOWED_HOSTS=abc123.ngrok-free.app
