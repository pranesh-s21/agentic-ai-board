# ── Cohere / North chat (POC) ────────────────────────────────────────────────
# Copy to .env and fill in your keys. Restart the chat server after changes.

# Provider: north | cohere | mock (auto-detects if unset)
# CHAT_PROVIDER=north

# Cohere API key (required for cohere mode; also used as fallback auth for north)
COHERE_API_KEY=

# Cohere Chat API base URL (default: https://api.cohere.com)
# For private/North deployments, set to your deployment URL
COHERE_BASE_URL=https://api.cohere.com

# Model for Cohere Chat API (cohere mode)
COHERE_MODEL=command-a-03-2025

# ── Cohere North agent (recommended for POC) ─────────────────────────────────
# Option A: full agent chat URL from your North instance
# NORTH_CHAT_URL=https://your-north.example.com/api/v1/agents/YOUR_AGENT_ID/chat

# Option B: base URL + agent ID (server builds the URL)
# NORTH_BASE_URL=https://your-north.example.com
# NORTH_AGENT_ID=your-agent-id

# Optional separate North API key (defaults to COHERE_API_KEY)
# NORTH_API_KEY=

# Chat server port (default 3001)
PORT=3001
